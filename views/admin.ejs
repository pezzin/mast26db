<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Database</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #1a1a2e;
      color: #eee;
      min-height: 100vh;
      padding: 20px;
    }
    .container { max-width: 1200px; margin: 0 auto; }
    h1 { margin-bottom: 10px; color: #00d9ff; }
    a { color: #00d9ff; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .section {
      background: #16213e;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
    }
    h2 { color: #00d9ff; margin-bottom: 15px; font-size: 1.2rem; }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }
    th, td {
      padding: 10px;
      text-align: left;
      border-bottom: 1px solid #2a3a5e;
    }
    th { background: #0f3460; color: #00d9ff; }
    tr:hover { background: #1f2b4a; }
    .badge {
      background: #00d9ff;
      color: #1a1a2e;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 0.85rem;
      margin-right: 8px;
    }
    textarea {
      width: 100%;
      min-height: 100px;
      background: #0f3460;
      border: 1px solid #00d9ff;
      color: #eee;
      border-radius: 8px;
      padding: 12px;
      font-family: 'Consolas', monospace;
      font-size: 14px;
      resize: vertical;
    }
    .btn {
      background: #00d9ff;
      color: #1a1a2e;
      border: none;
      padding: 10px 20px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
      margin-top: 10px;
    }
    .btn:hover { background: #00b8d9; }
    .error { color: #ff6b6b; background: #2a1a1a; padding: 10px; border-radius: 8px; margin-top: 10px; }
    .success { color: #51cf66; }
    pre {
      background: #0f3460;
      padding: 15px;
      border-radius: 8px;
      overflow-x: auto;
      font-size: 13px;
    }
    .back-link { margin-bottom: 20px; display: inline-block; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 15px; }
    .stat-card { background: #0f3460; border-radius: 10px; padding: 20px; text-align: center; }
    .stat-number { font-size: 2rem; font-weight: bold; color: #ffd93d; }
    .stat-label { font-size: 0.85rem; color: #aaa; margin-top: 5px; }
    .bar-chart { display: flex; flex-direction: column; gap: 8px; }
    .bar-row { display: flex; align-items: center; gap: 10px; }
    .bar-label { width: 120px; font-size: 0.85rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .bar-container { flex: 1; background: #0f3460; border-radius: 4px; height: 20px; overflow: hidden; }
    .bar-fill { background: linear-gradient(90deg, #00d9ff, #764ba2); height: 100%; transition: width 0.3s; }
    .bar-value { width: 50px; text-align: right; font-size: 0.85rem; color: #aaa; }
    .scroll-table { max-height: 300px; overflow-y: auto; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/" class="back-link">← Torna alla home</a>
    <h1>Database Admin</h1>
    
    <% if (stats) { %>
    <div class="section">
      <h2>Statistiche Visite</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number"><%= stats.total %></div>
          <div class="stat-label">Visite Totali</div>
        </div>
        <div class="stat-card">
          <div class="stat-number"><%= stats.today %></div>
          <div class="stat-label">Oggi</div>
        </div>
        <div class="stat-card">
          <div class="stat-number"><%= stats.week %></div>
          <div class="stat-label">Ultimi 7 giorni</div>
        </div>
      </div>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div>
          <h3 style="color: #00d9ff; margin-bottom: 10px;">Pagine più visitate</h3>
          <div class="bar-chart">
            <% const maxVisits = stats.byPath[0]?.visits || 1; %>
            <% stats.byPath.forEach(p => { %>
              <div class="bar-row">
                <div class="bar-label" title="<%= p.path %>"><%= p.path %></div>
                <div class="bar-container">
                  <div class="bar-fill" style="width: <%= (p.visits / maxVisits) * 100 %>%"></div>
                </div>
                <div class="bar-value"><%= p.visits %></div>
              </div>
            <% }) %>
          </div>
        </div>
        
        <div>
          <h3 style="color: #00d9ff; margin-bottom: 10px;">Visite per giorno (ultimi 30)</h3>
          <div class="bar-chart" style="max-height: 180px; overflow-y: auto;">
            <% const maxDay = stats.byDay[0]?.visits || 1; %>
            <% stats.byDay.slice(0, 14).forEach(d => { %>
              <div class="bar-row">
                <div class="bar-label"><%= new Date(d.date).toLocaleDateString('it-IT', {day: '2-digit', month: 'short'}) %></div>
                <div class="bar-container">
                  <div class="bar-fill" style="width: <%= (d.visits / maxDay) * 100 %>%"></div>
                </div>
                <div class="bar-value"><%= d.visits %></div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
      
      <h3 style="color: #00d9ff; margin: 20px 0 10px;">Ultime 50 visite</h3>
      <div class="scroll-table">
        <table>
          <thead>
            <tr>
              <th>Data/Ora</th>
              <th>Pagina</th>
              <th>IP</th>
              <th>Browser</th>
            </tr>
          </thead>
          <tbody>
            <% stats.recent.forEach(v => { %>
              <tr>
                <td><%= new Date(v.created_at).toLocaleString('it-IT') %></td>
                <td><%= v.path %></td>
                <td><%= v.ip_hash %></td>
                <td style="font-size: 0.8rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis;"><%= v.user_agent?.split(')')[0]?.substring(0, 50) || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>
    
    <div class="section">
      <h2>Tabelle (<%= tables.length %>)</h2>
      <% tables.forEach(t => { %>
        <span class="badge"><%= t.table_name %></span>
      <% }) %>
    </div>

    <div class="section">
      <h2>Tabella: notes (<%= notes.length %> righe)</h2>
      <% if (notes.length > 0) { %>
        <table>
          <thead>
            <tr>
              <% Object.keys(notes[0]).forEach(col => { %>
                <th><%= col %></th>
              <% }) %>
            </tr>
          </thead>
          <tbody>
            <% notes.forEach(row => { %>
              <tr>
                <% Object.values(row).forEach(val => { %>
                  <td><%= val %></td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>Nessun dato</p>
      <% } %>
    </div>

    <div class="section">
      <h2>Esegui Query SQL</h2>
      <form action="/admin/query" method="POST">
        <textarea name="query" placeholder="SELECT * FROM notes;">SELECT * FROM notes;</textarea>
        <button type="submit" class="btn">Esegui</button>
      </form>
      <% if (locals.queryError) { %>
        <div class="error"><%= queryError %></div>
      <% } %>
      <% if (locals.queryResult) { %>
        <h3 style="margin-top: 15px; color: #51cf66;">Risultati (<%= queryResult.length %> righe)</h3>
        <pre><%= JSON.stringify(queryResult, null, 2) %></pre>
      <% } %>
    </div>
  </div>
</body>
</html>
